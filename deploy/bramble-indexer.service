[Unit]
Description=Bramble indexer (crawler + search API)
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/bramble/server
ExecStart=/usr/bin/node index.js
Restart=always
RestartSec=5
User=root
Environment=NODE_ENV=production
# Optional overrides:
# Environment=PORT=8787
# Environment=DATA_DIR=/var/lib/bramble
# Environment=CRAWL_BATCH_SIZE=12

[Install]
WantedBy=multi-user.target
